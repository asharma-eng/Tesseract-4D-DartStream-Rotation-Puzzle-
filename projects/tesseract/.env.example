# DartStream Developer Credentials (User Session auth)
DARTSTREAM_EMAIL=your-service-account@domain.com
DARTSTREAM_PASSWORD=your-secure-password
DARTSTREAM_FIREBASE_API_KEY=your-firebase-api-key

# DartStream OAuth2 Credentials (Machine-to-Machine auth)
DARTSTREAM_CLIENT_ID=your-oauth-client-id
DARTSTREAM_CLIENT_SECRET=your-oauth-client-secret
